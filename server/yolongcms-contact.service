[Unit]
Description=YolongCMS Contact Server - Receive website contact form submissions
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/yolongcms-contact
ExecStart=/usr/bin/python3 /home/admin/yolongcms-contact/server.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
